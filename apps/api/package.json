{
  "name": "@agentdock/api",
  "version": "0.1.0",
  "description": "AgentDock's HTTP API: POST /jobs, GET /jobs/:id, GET /jobs/:id/executions, GET /executions/:id, GET /providers, GET /providers/:id, GET /providers/health, GET /routing, GET /health, and the deprecated POST /execute.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "nx": {
    "tags": [
      "scope:app"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.spec.json",
    "test": "vitest run",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@agentdock/foundation-config": "workspace:*",
    "@agentdock/foundation-db": "workspace:*",
    "@agentdock/kernel-ai-router": "workspace:*",
    "@agentdock/kernel-job-service": "workspace:*",
    "@agentdock/kernel-planner": "workspace:*",
    "@agentdock/kernel-prompt-builder": "workspace:*",
    "@agentdock/kernel-provider-registry": "workspace:*",
    "@agentdock/kernel-workflow-engine": "workspace:*",
    "@agentdock/plugin-provider-ollama": "workspace:*",
    "@agentdock/provider-abstraction": "workspace:*",
    "@agentdock/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "5.6.3",
    "vitest": "4.1.9"
  }
}
