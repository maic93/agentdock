{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@agentdock/kernel-planner": ["packages/kernel/planner/src/index.ts"],
      "@agentdock/kernel-workflow-engine": ["packages/kernel/workflow-engine/src/index.ts"],
      "@agentdock/kernel-ai-router": ["packages/kernel/ai-router/src/index.ts"],
      "@agentdock/kernel-prompt-builder": ["packages/kernel/prompt-builder/src/index.ts"],
      "@agentdock/kernel-model-registry": ["packages/kernel/model-registry/src/index.ts"],
      "@agentdock/kernel-tool-registry": ["packages/kernel/tool-registry/src/index.ts"],
      "@agentdock/kernel-event-bus": ["packages/kernel/event-bus/src/index.ts"],

      "@agentdock/foundation-memory": ["packages/foundation/memory/src/index.ts"],
      "@agentdock/foundation-knowledge-base": ["packages/foundation/knowledge-base/src/index.ts"],
      "@agentdock/foundation-artifact-manager": [
        "packages/foundation/artifact-manager/src/index.ts"
      ],
      "@agentdock/foundation-scheduler": ["packages/foundation/scheduler/src/index.ts"],
      "@agentdock/foundation-auth": ["packages/foundation/auth/src/index.ts"],
      "@agentdock/foundation-config": ["packages/foundation/config/src/index.ts"],
      "@agentdock/foundation-db": ["packages/foundation/db/src/index.ts"],
      "@agentdock/foundation-observability": ["packages/foundation/observability/src/index.ts"],

      "@agentdock/provider-abstraction": ["packages/providers/provider-abstraction/src/index.ts"],

      "@agentdock/shared-types": ["packages/shared/types/src/index.ts"],
      "@agentdock/shared-sdk": ["packages/shared/sdk/src/index.ts"],
      "@agentdock/shared-testing-utils": ["packages/shared/testing-utils/src/index.ts"],
      "@agentdock/shared-ui-kit": ["packages/shared/ui-kit/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", "**/dist/**"]
}
