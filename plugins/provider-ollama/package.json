{
  "name": "@agentdock/plugin-provider-ollama",
  "version": "0.1.0",
  "description": "The first-party Ollama provider plugin: text-generation via a local or remote Ollama instance.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "tags": [
      "type:plugin"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.spec.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentdock/provider-abstraction": "workspace:*",
    "@agentdock/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "typescript": "5.6.3",
    "vitest": "4.1.9"
  }
}
