# Strict, non-phantom dependency resolution is one of the reasons pnpm was
# chosen over Yarn/npm (see ADR 0002). These settings preserve that guarantee
# rather than accidentally loosening it with permissive defaults.

# Never hoist dependencies into a flat node_modules — this is what prevents
# a package from silently importing a dependency it never declared.
shamefully-hoist=false
hoist=false

# Fail fast on peer dependency mismatches instead of silently ignoring them.
strict-peer-dependencies=true

# Keep lockfile changes explicit and reviewable; never auto-update on install.
frozen-lockfile=false
prefer-frozen-lockfile=true

# Pin the exact engine-strict behavior so CI and local machines fail the same
# way if someone is on the wrong Node/pnpm version.
engine-strict=true
