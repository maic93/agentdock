# AgentDock environment variables.
#
# Strategy:
#   - All variables are prefixed AGENTDOCK_<SUBSYSTEM>_<NAME>, per the naming
#     standards in docs/architecture (Repository Foundation, Section 5).
#   - This file lists every variable the CURRENT repository foundation
#     actually reads (i.e. nothing here is speculative for unbuilt features).
#   - Copy this file to `.env` and adjust values; `.env` is gitignored.
#   - Nothing in this file is a secret — real secrets are never committed,
#     even as example placeholders that look plausible.

# --- Runtime -----------------------------------------------------------
# Standard Node environment flag, read by tooling (e.g. to decide whether to
# enable source maps / verbose logging in local dev vs CI).
NODE_ENV=development

# --- Development services (infra/docker/docker-compose.dev.yml) --------
# The dev Compose file currently provisions network/volume scaffolding only
# (see infra/docker/README.md) — these ports are reserved for the services
# that will attach to it as foundation packages are implemented.
AGENTDOCK_DEV_NETWORK_NAME=agentdock_dev

# --- Nx / CI -------------------------------------------------------------
# Optional: enables Nx Cloud distributed caching if you have an access token.
# Leave unset to use local-only Nx caching, which is the default and requires
# no external account.
NX_CLOUD_ACCESS_TOKEN=

# Works around a known Nx daemon socket-path-length failure on deep clone
# paths — see scripts/setup/bootstrap.sh and .github/workflows/ci.yml for
# the full explanation. The bootstrap script sets this automatically; it's
# listed here so it's visible if you're not using that script.
NX_SOCKET_DIR=/tmp/nx-agentdock
