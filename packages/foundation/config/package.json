{
  "name": "@agentdock/foundation-config",
  "version": "0.1.0",
  "description": "Layered configuration resolution. The only package that reads process.env directly.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "tags": [
      "scope:foundation"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.spec.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "5.6.3",
    "vitest": "4.1.9"
  }
}
