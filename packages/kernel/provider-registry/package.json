{
  "name": "@agentdock/kernel-provider-registry",
  "version": "0.1.0",
  "description": "Holds and answers questions about registered providers, without ever importing a concrete plugin.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "tags": [
      "scope:kernel"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.spec.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentdock/provider-abstraction": "workspace:*",
    "@agentdock/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vitest": "4.1.9"
  }
}
